{
  "pluginAlias": "TuyaHomeMate",
  "pluginType": "platform",
  "singular": false,
  "headerDisplay": "Local LAN control for HomeMate 3+1 Tuya switch/fan panels. Add the device name, Tuya device ID, and local key; the plugin handles discovery, protocol version, and the fixed HomeMate DP map.",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "TuyaHomeMate"
      },
      "devices": {
        "title": "Devices",
        "type": "array",
        "items": {
          "title": "HomeMate 3+1 Device",
          "type": "object",
          "required": [
            "name",
            "id",
            "key"
          ],
          "properties": {
            "name": {
              "title": "Device Name",
              "type": "string",
              "description": "Friendly name shown in the Home app."
            },
            "id": {
              "title": "Tuya Device ID",
              "type": "string",
              "description": "The local Tuya device ID."
            },
            "key": {
              "title": "Local Key",
              "type": "string",
              "description": "The Tuya local key. Enter it exactly as provided; symbol keys are supported."
            }
          }
        }
      }
    }
  }
}
